{
        "name": "SimpleTable",
        "author": ["Johan the Ghost", "John Bray", "Wolfgang Fahl"],
        "url": "https://github.com/WolfgangFahl/SimpleTable",
        "description": "Convert tab-separated or similar data into a Wiki table",
        "type": "parserhook",
        "requires": {
                "MediaWiki": ">= 1.35.0"
        },
        "AutoloadClasses": {
                "SimpleTable": "SimpleTable.php",
                "SimpleTableRenderer": "SimpleTableRenderer.php"
        },
        "Hooks": {
        "ParserFirstCallInit": "SimpleTable::onParserFirstCallInit"
        },
        "manifest_version": 2
}
